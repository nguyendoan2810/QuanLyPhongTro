@* @{
    var phongList = ViewBag.PhongList as List<QuanLyPhongTro.Models.Phong>;
    phongList = phongList ?? new List<QuanLyPhongTro.Models.Phong>();
} *@

<div id="rooms-section" class="section hidden">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center">
            <h3 class="text-lg font-semibold text-gray-800">Danh sách phòng</h3>
            <button onclick="openModal('roomModal')" class="btn-primary text-white px-4 py-2 rounded-lg flex items-center">
                <i class="fas fa-plus mr-2"></i>Thêm phòng
            </button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left">Tên phòng</th>
                        <th class="px-6 py-3 text-left">Tầng</th>
                        <th class="px-6 py-3 text-left">Loại phòng</th>
                        <th class="px-6 py-3 text-left">Diện tích</th>
                        <th class="px-6 py-3 text-left">Giá phòng</th>
                        <th class="px-6 py-3 text-left">Địa chỉ</th>
                        <th class="px-6 py-3 text-left">Trạng thái</th>
                        <th class="px-6 py-3 text-left">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.PhongList != null && ViewBag.PhongList.Count > 0)
                    {
                        @foreach (var phong in ViewBag.PhongList)
                        {
                            <tr class="border-b">
                                <td class="px-6 py-4">@phong.TenPhong</td>
                                <td class="px-6 py-4">@phong.Tang</td>
                                <td class="px-6 py-4">@phong.LoaiPhong</td>
                                <td class="px-6 py-4">@phong.DienTich m²</td>
                                <td class="px-6 py-4">@phong.GiaPhong</td>
                                <td class="px-6 py-4">@phong.DiaChi</td>
                                <td class="px-6 py-4">@phong.TrangThai</td>
                                <td class="px-6 py-4">
                                    <button onclick="editRoom('@phong.MaPhong')" class="text-blue-600 mr-3 hover:underline">
                                        <i class="fas fa-edit mr-1"></i>Sửa
                                    </button>
                                    <button onclick="deleteRoom('@phong.MaPhong')" class="text-red-600 hover:underline">
                                        <i class="fas fa-trash mr-1"></i>Xóa
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
